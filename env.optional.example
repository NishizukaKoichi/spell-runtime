SPELL_API_PORT=8787
SPELL_REQUIRES_KEY_PORT=8788
SPELL_MARKET_PORT=8789
SPELL_BILLING_PORT=8790

# Auth tokens (set if you want API auth for these sidecars)
# SPELL_REQUIRES_KEY_API_TOKEN=replace_me
# SPELL_BILLING_API_TOKEN=replace_me

# Spell requires Key store path
SPELL_REQUIRES_KEY_STORE_PATH=/root/.spell/spell-requires-key.v1.json

# Spell Market catalog path
SPELL_MARKET_CATALOG_PATH=/root/.spell/market/catalog.v1.json

# Billing issuer configuration
SPELL_BILLING_ISSUER=spell-runtime-market
SPELL_BILLING_KEY_ID=default
SPELL_BILLING_PRIVATE_KEY_PATH=/root/.spell/billing/issuer.private.pem
